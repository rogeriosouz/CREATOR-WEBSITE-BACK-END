{
  "name": "back-end",
  "version": "1.0.0",
  "main": "index.js",
  "author": "rogerio",
  "license": "MIT",
  "scripts": {
    "setup": "tsx src/setup.ts",
    "build": "tsup src --out-dir build",
    "deploy": "npm run build && pm2 start npm --name back-end -- run start:build && sudo systemctl restart nginx",
    "start:dev": "tsx watch src/server.ts",
    "start:build": "node build/server.js",
    "lint": "eslint --fix --ext .ts .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@eslint/js": "9.4.0",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "25.3.5",
    "@typescript-eslint/eslint-plugin": "7.11.0",
    "@typescript-eslint/parser": "7.11.0",
    "eslint": "8.57.0",
    "globals": "15.3.0",
    "typescript": "5.4.5",
    "typescript-eslint": "7.11.0"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.2.0",
    "@fastify/rate-limit": "10.3.0",
    "axios": "1.13.6",
    "dotenv": "16.4.5",
    "fastify": "5.8.2",
    "jsonwebtoken": "9.0.2",
    "moment-timezone": "0.5.45",
    "nodemailer": "8.0.1",
    "postgres": "3.4.4",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18",
    "zod": "3.23.8"
  }
}